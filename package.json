{
  "name": "ipl-auction",
  "version": "1.0.0",
  "description": "Real-time IPL Player Auction with friends",
  "scripts": {
    "build": "echo 'Static site ready'",
    "start": "node server.js",
    "dev": "node server.js",
    "players:sync-images": "node scripts/cloudinary-player-sync.js",
    "players:refresh-images": "node scripts/cloudinary-player-sync.js --refresh-existing",
    "players:map-cloudinary": "node scripts/cloudinary-player-sync.js --map-only --refresh-existing",
    "players:sync-web": "node scripts/cloudinary-player-sync.js --source=web --refresh-existing --delayMs=120",
    "players:sync-espn": "node scripts/cloudinary-player-sync.js --source=web --refresh-existing --delayMs=120",
    "players:force-espn-headshots": "node scripts/espn-headshot-map.js"
  },
  "keywords": [
    "ipl",
    "auction",
    "cricket",
    "Firebase"
  ],
  "author": "Tilak",
  "dependencies": {
    "cloudinary": "^2.9.0",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  }
}
